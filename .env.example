# ═══════════════════════════════════════════════════════════════
# EXPLOSION_BOT v4 — Environment Variables
# انسخ هذا الملف إلى .env واملأ المفاتيح
# في Railway: Variables → أضف كل مفتاح
# ═══════════════════════════════════════════════════════════════

# ───── REQUIRED ─────
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# ───── OPTIONAL: Independent data sources (تحسن الدقة بشكل كبير) ─────
WHALE_ALERT_API_KEY=
MASSIVE_API_KEY=
TWELVEDATA_API_KEY=
COINMARKETCAP_API_KEY=
ETHERSCAN_API_KEY=

# ───── OPTIONAL: AI deep analysis ─────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ───── TUNING ─────
SCAN_TOP_N=100
MIN_VOLUME_USD=500000
MIN_CONFIDENCE=65
MIN_SOURCES_AGREE=4
ALERT_COOLDOWN=3600
SCAN_INTERVAL=180
MONITOR_INTERVAL=60
DEFAULT_MODE=day
DB_PATH=/tmp/explosion_bot.db
LOG_LEVEL=INFO
